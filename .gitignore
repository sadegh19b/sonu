# =========================
# SONU .gitignore (Tauri v2)
# =========================

# Dependencies
node_modules/

# Build outputs
dist/
build/
out/

# Rust build cache
**/target/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local

# ML model files (downloaded at runtime)
*.bin
*.gguf
*.ggml
*.onnx.part
*.nemo
models--*/

# Application data (user-generated)
config.json
history.json
data/settings.json
**/data/*.json.backup
**/data/settings_backup.json

# Logs
*.log
logs/

# Testing
coverage/
.nyc_output/
**/jest-*.json

# Python (legacy)
__pycache__/
*.py[cod]
.Python
env/
venv/
.venv

# Temp / cache
*.tmp
*.temp
*.bak
*.backup
.cache/
artifacts/
xet/

# Agent memory
.agentmd_memory/

# Terminal paste images
.cp-images/

# Platform installers (built locally)
*.exe
*.dmg
*.pkg
*.asar