{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SONU",
  "version": "2.2.1",
  "identifier": "com.sonu.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "SONU - Offline Voice Typing",
        "width": 680,
        "height": 570,
        "minWidth": 680,
        "minHeight": 570,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://blob.handy.computer https://github.com https://api.openai.com https://api.anthropic.com https://api.groq.com; font-src 'self'; media-src 'self' blob:; frame-src 'none'; object-src 'none';",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$RESOURCE/**",
            "$APPDATA/models/**",
            "$APPDATA/recordings/**",
            "$APPDATA/history/**"
          ],
          "deny": [
            "$APPDATA/*.json",
            "$APPDATA/settings.json",
            "$HOME/**",
            "$DESKTOP/**",
            "$DOCUMENT/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {
      "signCommand": ""
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5Rjk0MUQ0MkQ4QjM1MkUKUldRdU5Zc3QxRUg1U1JLbVdKWU1wRldIU2xaeko1ZzJ3RFNMYkhTN0VXR3lYRFpURkt0eCt2UFAK",
      "endpoints": [
        "https://github.com/ai-dev-2024/sonu/releases/latest/download/latest.json"
      ]
    }
  }
}
